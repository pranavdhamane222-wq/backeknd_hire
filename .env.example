# Local machine / CI: use the External Database URL from the Render dashboard
# (hostname ends in .oregon-postgres.render.com or similar).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.REGION-postgres.render.com/DATABASE

# Optional alias (app treats same as DATABASE_URL)
# RENDER_DB_URL=postgresql://USER:PASSWORD@HOST.REGION-postgres.render.com/DATABASE

# Only works from another Render service or Render shell (private network; short hostname like dpg-xxx-a).
# Render usually injects this automatically as DATABASE_URL when you link the DB to a Web Service.
# RENDER_INTERNAL_DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxx-a/DATABASE
